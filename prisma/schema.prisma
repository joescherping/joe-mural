generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
}

model Purchase {
  id     Int    @id @default(autoincrement())
  price  Float
  status String
}
