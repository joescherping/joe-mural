{
  "openapi": "3.0.3",
  "info": {
    "title": "Joe Mural API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://joe-mural.onrender.com"
    }
  ],
  "paths": {
    "/store/products": {
      "get": {
        "summary": "List all products",
        "responses": {
          "200": {
            "description": "Product list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to load products",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/store/purchases": {
      "post": {
        "summary": "Create a new purchase for a given price",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                  "properties": {
                    "price": {
                      "type": "number",
                      "description": "Total price to be paid (token amount)"
                    }
                  },
                  "required": [
                    "price"
                  ],
                  "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Purchase created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "purchase": {
                      "$ref": "#/components/schemas/Purchase"
                    },
                    "instructions": {
                      "type": "string"
                    },
                    "address": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "purchase",
                    "instructions",
                    "address"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to create purchase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/balance-changes": {
      "post": {
        "summary": "Handle balance-change webhook from Mural",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transactionId": {
                    "type": "string"
                  }
                },
                "required": [
                  "transactionId"
                ],
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Webhook accepted (and optionally purchase updated)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": {
                      "type": "boolean"
                    },
                    "updated": {
                      "type": "integer",
                      "description": "How many purchases were updated"
                    }
                  },
                  "required": [
                    "received",
                    "updated"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Missing transactionId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to update purchases",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/purchases": {
      "get": {
        "summary": "List all purchases (for admin/vendor)",
        "responses": {
          "200": {
            "description": "Purchase list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Purchase"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to load purchases",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "price",
          "createdAt"
        ]
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "price": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "transactionId": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "price",
          "status",
          "transactionId",
          "createdAt"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      }
    }
  }
}

